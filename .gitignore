# Source data — large (700+ MB once PortWatch downloads accumulate) and
# regenerable from the source APIs by running scripts/energy/update_data.py.
# Don't push to GitHub; rebuild locally. Use `data/*` (not `data/`) so the
# exceptions below can re-include specific small curated configs.
data/*

# Exceptions: small curated configs that drive the pipeline and need to be
# in the repo.
!data/trigger_thresholds.json

# Reference copies of the precursor dashboards — kept locally for visual
# reference but not part of Iran Monitor itself.
reference/

# Working artifacts — local review screenshots, draft showcase decks.
# Kept locally for review iterations; not part of the deployed dashboard.
screenshots/
middle_east_monitor_showcase.pptx

# Python bytecode
__pycache__/
*.pyc
*.pyo

# Build outputs (regenerable)
outputs/

# Runtime logs (created by ingest scripts; rotate locally, no need to push)
logs/

# macOS
.DS_Store

# Editor
.vscode/
.idea/
*.swp
*~

# Secrets
.env
.env.local
*.token

# Local-only showcase prep — kept on disk, not tracked
SHOWCASE_WALKTHROUGH.md
ME_Monitor_Showcase_Transcript.docx
